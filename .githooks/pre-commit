#!/usr/bin/env bash

# Pre-commit hook: VERIFY formatting of the staged files without mutating them.
# It never re-stages, so partially-staged files keep their unstaged hunks out of
# the commit. If something is not formatted, the commit aborts with guidance —
# run the formatter yourself and re-stage. Activated by composer setup via:
# git config core.hooksPath .githooks

set -euo pipefail

# Collect staged (added/copied/modified/renamed) files, NUL-delimited so paths
# with spaces survive. Partition them by what tool should check them.
php_files=()
fe_files=()
while IFS= read -r -d '' file; do
    case "$file" in
        *.php)
            php_files+=("$file")
            ;;
        resources/*.ts | resources/*.vue | resources/*.css | resources/*.js)
            fe_files+=("$file")
            ;;
    esac
done < <(git diff --cached --name-only --diff-filter=ACMR -z)

status=0

if [ ${#php_files[@]} -gt 0 ]; then
    if ! ./vendor/bin/pint --test "${php_files[@]}" >/dev/null 2>&1; then
        echo "❌ Pint: staged PHP files need formatting."
        echo "   Fix with: composer format && git add <files>"
        status=1
    fi
fi

if [ ${#fe_files[@]} -gt 0 ]; then
    if ! npx prettier --check "${fe_files[@]}" >/dev/null 2>&1; then
        echo "❌ Prettier: staged frontend files need formatting."
        echo "   Fix with: npm run format && git add <files>"
        status=1
    fi
fi

if [ "$status" -ne 0 ]; then
    echo "Pre-commit aborted — your working tree was left untouched."
    exit 1
fi

exit 0
